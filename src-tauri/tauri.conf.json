{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simple SDM",
  "version": "0.1.1",
  "identifier": "cc.raedb.simple-sdm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Simple SDM",
        "width": 1500,
        "height": 940,
        "minWidth": 1160,
        "minHeight": 740
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzOEZDMTFEQ0UxRTAxM0QKUldROUFSN09IY0dQUThqYTBPU280ZzA1ZnJ6eEg4WjdKZTNXUTF6aStESHBGWENnbWd1K3R2aHMK"
    }
  }
}
