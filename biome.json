{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!dist",
      "!node_modules",
      "!src-tauri/target",
      "!test-results",
      "!.agents",
      "!.claude",
      "!.playwright-cli",
      "!.tmp"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
