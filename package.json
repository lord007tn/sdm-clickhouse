    "test:e2e": "playwright test",
    "check:tauri": "node scripts/check-tauri.mjs",
    "check:versions": "node scripts/check-version-consistency.mjs",
    "validate": "pnpm check:versions && pnpm typecheck && pnpm lint && pnpm format:check && pnpm knip && pnpm build && pnpm check:tauri",
    "knip": "knip",
    "knip:strict": "knip --production",
    "preview": "vite preview",
    "tauri": "tauri"
